```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.class
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build and distribution
dist/
build/
target/
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/

# Image files (if accidentally added)
*.png
*.jpg
*.jpeg
*.bmp
*.gif
*.webm
```